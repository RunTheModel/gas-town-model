#Paste this into EDOTOR.NET for a rendered diagram (or use your favorite Graphviz DOT visualizer)
digraph Composition {
  rankdir=LR;
  compound=true;
  node [shape=box, style="rounded,filled", fillcolor=white];
  "May" [label="May\nMayor"];
  "Con" [label="Con\nConvoy"];
  "Fed" [label="Fed\nFeeder"];
  "Ref" [label="Ref\nRefinery"];
  "Lnd" [label="Lnd\nLanding"];
  "Iss1" [label="Iss1\nIssue"];
  "Iss2" [label="Iss2\nIssue"];
  "Pol1" [label="Pol1\nPolecat"];
  "Pol2" [label="Pol2\nPolecat"];
  "Mr1" [label="Mr1\nMR"];
  "Mr2" [label="Mr2\nMR"];
  "Wt1" [label="Wt1\nWorktree"];
  "Wt2" [label="Wt2\nWorktree"];
  "Hk1" [label="Hk1\nHook"];
  "Hk2" [label="Hk2\nHook"];
  "May" -> "Con" [label="LAUNCH"];
  "Con" -> "May" [label="CONVOY_DONE"];
  "Iss1" -> "Con" [label="ISS1_OBSERVE" style=dotted];
  "Iss2" -> "Con" [label="ISS2_OBSERVE" style=dotted];
  "Mr1" -> "Con" [label="MR1_OBSERVE" style=dotted];
  "Mr2" -> "Con" [label="MR2_OBSERVE" style=dotted];
  "Pol1" -> "Con" [label="POL1_OBSERVE" style=dotted];
  "Pol2" -> "Con" [label="POL2_OBSERVE" style=dotted];
  "Lnd" -> "Con" [label="LANDING_OBSERVE" style=dotted];
  "Fed" -> "Iss1" [label="SLING1"];
  "Fed" -> "Iss2" [label="SLING2"];
  "Con" -> "Fed" [label="CONVOY_OBSERVE" style=dotted];
  "Pol1" -> "Ref" [label="MERGE_READY"];
  "Pol2" -> "Ref" [label="MERGE_READY"];
  "Ref" -> "Mr1" [label="MR_NOTIFY1"];
  "Ref" -> "Mr2" [label="MR_NOTIFY2"];
  "Lnd" -> "Wt1" [label="CLEAN1"];
  "Lnd" -> "Wt2" [label="CLEAN2"];
  "Con" -> "Lnd" [label="CONVOY_OBSERVE" style=dotted];
  "Wt1" -> "Lnd" [label="WT1_OBSERVE" style=dotted];
  "Wt2" -> "Lnd" [label="WT2_OBSERVE" style=dotted];
  "Pol1" -> "Iss1" [label="POLECAT_OBSERVE" style=dotted];
  "Pol2" -> "Iss2" [label="POLECAT_OBSERVE" style=dotted];
  "Fed" -> "Pol1" [label="SLING"];
  "Hk1" -> "Pol1" [label="AGENT"];
  "Iss1" -> "Pol1" [label="ISSUE_OBSERVE" style=dotted];
  "Fed" -> "Pol2" [label="SLING"];
  "Hk2" -> "Pol2" [label="AGENT"];
  "Iss2" -> "Pol2" [label="ISSUE_OBSERVE" style=dotted];
  "Pol1" -> "Mr1" [label="POLECAT_OBSERVE" style=dotted];
  "Pol2" -> "Mr2" [label="POLECAT_OBSERVE" style=dotted];
}
